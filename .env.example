# Google Gemini API key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Number of posts to process (default: 10)
MAX_POSTS=10

# Save directory for output .txt files
# Defaults to ~/Desktop/tjm-project if not set
SAVE_DIR=C:\Users\YourName\Desktop\tjm-project

# Set to "false" to skip saving annotated screenshots (faster)
ENABLE_VISUALIZATION=true
